# ── Feature flags (Unleash) ────────────────────────────────────────────────────
# Unleash Frontend API URL, e.g. https://your-instance.unleash-hosted.com/api/frontend
NEXT_PUBLIC_UNLEASH_URL=
# Unleash Frontend token (create one under Configure → API Access, type: Frontend)
NEXT_PUBLIC_UNLEASH_CLIENT_KEY=

# ── Firebase — required for cloud playlist sync (optional feature) ─────────────
# Remove these if Firebase is not being used
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
